# Public API (required). Must be the URL where Laravel actually answers /api/v1/... (JSON), NOT the static SPA host.
#
# If https://www.example.com only serves your React build, then https://www.example.com/api/v1/... will 404 with HTML
# (Hostinger "page not found"). Use a separate API subdomain with document root = Laravel `public/`, e.g.:
#   VITE_API_URL=https://api.example.com
#   VITE_API_URL=https://api.example.com/api/v1
#
# Local dev (`npm run dev`): full `https://…` is rewritten to `/api/v1` + Vite proxies to this host (see vite.config.ts).
# Production build: uses the full resolved URL.
VITE_API_URL=https://api.example.com
VITE_API_URL=https://www.offerlifetime.com/api/v1

# Legacy alias (optional if `VITE_API_URL` is set):
# VITE_API_BASE_URL=https://www.offerlifetime.com/api/v1

# Only if the resolved base is relative in dev, e.g. `/api/v1`:
# VITE_DEV_PROXY_TARGET=https://www.offerlifetime.com
